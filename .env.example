# ============================================================
# fatturapp — variabili d'ambiente
# Copia questo file in .env e compila i valori reali.
# NON committare mai il file .env nel repository!
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_SERVER=localhost
DB_USERNAME=fatturapp
DB_PASSWORD=CAMBIA_CON_PASSWORD_SICURA
DB_NAME=fatturazione

# ── Applicazione ─────────────────────────────────────────────
# URL completo dell'app (con trailing slash)
SITE_URL=https://tuodominio.it/fatturazione/

# ── PayPal ───────────────────────────────────────────────────
# Ottieni le credenziali da: https://developer.paypal.com/developer/applications
# Per il sandbox usa credenziali dell'ambiente "Sandbox", per live usa "Live"
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=INSERISCI_CLIENT_ID_PAYPAL
PAYPAL_CLIENT_SECRET=INSERISCI_CLIENT_SECRET_PAYPAL

# ID del piano ricorrente creato con setup/create-paypal-plan.php
PAYPAL_PLAN_ID_PRO=P-XXXXXXXXXXXXXXXXXXXXXXXXX

# ID webhook configurato su https://developer.paypal.com/developer/webhooksSimulator
# (lascia vuoto in sandbox — la verifica firma viene saltata)
PAYPAL_WEBHOOK_ID=

# ── Email (SMTP) ─────────────────────────────────────────────
# Se lasci vuoti questi valori viene usata la funzione mail() di PHP (non affidabile)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tuoindirizzo@gmail.com
SMTP_PASSWORD=INSERISCI_APP_PASSWORD_GMAIL
SMTP_FROM=noreply@fatturapp.it
SMTP_FROM_NAME=fatturapp

# ── Opzionali ─────────────────────────────────────────────────
# Percentuale tasse forfettarie di default (sovrascritta da tb_anagrafiche)
# TAX_PERCENTAGE=35

# Dimensione massima upload in MB
# MAX_UPLOAD_MB=10
